{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/video_review.schema.json",
  "title": "Closing Price Video Review Evidence Record",
  "description": "Human-authored review note summary for external video takes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scene_id",
    "prompt_id",
    "review_notes_path",
    "review_notes",
    "take_ids",
    "selected_take",
    "round_status",
    "needs_prompt_revision",
    "storage_policy"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "prompt_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^SC\\d{4}__[a-z0-9\\-]+__v\\d{2}$"
    },
    "review_notes_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "review_notes": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "take_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^SC\\d{4}_TAKE\\d{3}$"
      }
    },
    "selected_take": {
      "type": ["string", "null"],
      "pattern": "^SC\\d{4}_TAKE\\d{3}$"
    },
    "round_status": {
      "type": "string",
      "enum": ["in_progress", "complete", "needs_prompt_revision", "blocked"]
    },
    "needs_prompt_revision": {
      "type": "boolean"
    },
    "storage_policy": {
      "const": "external_video_only"
    }
  }
}
