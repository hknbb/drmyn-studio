{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drmyn-studio/schemas/perspective_qc_report.schema.json",
  "title": "Perspective QC Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "perspective_qc_id",
    "status",
    "scene_id",
    "element_id",
    "prompt_pack_id",
    "operator_session_ref",
    "perspective_scores",
    "gate",
    "notes"
  ],
  "properties": {
    "schema_version": {"const": "0.x-draft"},
    "record_type": {"const": "perspective_qc_report"},
    "perspective_qc_id": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "locked", "materialized", "blocked", "rejected"]
    },
    "scene_id": {"type": "string", "pattern": "^SC\\d{4}$"},
    "element_id": {"type": "string", "minLength": 1},
    "prompt_pack_id": {"type": "string", "minLength": 1},
    "operator_session_ref": {"type": "string", "minLength": 1},
    "perspective_scores": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "prompt_id",
          "perspective",
          "identity_preservation",
          "perspective_usefulness",
          "material_palette_continuity",
          "production_reference_cleanliness",
          "hallucination_absence",
          "total_score",
          "decision"
        ],
        "properties": {
          "prompt_id": {"type": "string", "minLength": 1},
          "perspective": {
            "type": "string",
            "enum": [
              "front_hero",
              "three_quarter_left",
              "three_quarter_right",
              "rear_or_side",
              "right_profile_side",
              "left_profile_side",
              "front_reference",
              "left_reference",
              "right_reference",
              "three_quarter_medium_reference",
              "three_quarter_close_reference",
              "full_body_front",
              "three_quarter_waist",
              "close_portrait_front",
              "profile_full"
            ]
          },
          "identity_preservation": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "perspective_usefulness": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "material_palette_continuity": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "production_reference_cleanliness": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "hallucination_absence": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "character_description_strength": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 character QC criterion: does the image read as the intended person."},
          "identity_readability": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 character QC criterion: face/age/identity legibility."},
          "silhouette_readability": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 character QC criterion: silhouette and hair read."},
          "wardrobe_world_fit": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 character QC criterion: wardrobe-world continuity."},
          "expression_performance_readability": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 character QC criterion: expression/performance register."},
          "view_distinction": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 scale-angle QC criterion: each view is visibly distinct."},
          "scale_distinction": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 scale-angle QC criterion: framing scale is distinct between views."},
          "no_directional_confusion": {"type": ["integer", "null"], "minimum": 0, "maximum": 100, "description": "Optional v2 scale-angle QC criterion: no left/right directional confusion. Replaces legacy left/right accuracy scoring."},
          "total_score": {"type": ["integer", "null"], "minimum": 0, "maximum": 100},
          "decision": {"type": "string", "enum": ["pending", "pass", "revise", "fail"]}
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum_score", "can_advance_to_kling_reference"],
      "properties": {
        "minimum_score": {"type": "integer", "minimum": 0, "maximum": 100},
        "all_four_required": {"type": "boolean"},
        "all_perspectives_required": {"type": "boolean"},
        "can_advance_to_kling_reference": {"type": "boolean"}
      }
    },
    "notes": {"type": "string", "minLength": 1}
  }
}
