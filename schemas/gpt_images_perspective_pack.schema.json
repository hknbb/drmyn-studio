{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drmyn-studio/schemas/gpt_images_perspective_pack.schema.json",
  "title": "GPT Images Perspective Pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "prompt_pack_id",
    "status",
    "source_reference_id",
    "target_model",
    "target_role",
    "element_id",
    "element_type",
    "shared_preservation_instruction",
    "prompts",
    "qc_gate",
    "downstream_use"
  ],
  "properties": {
    "schema_version": {
      "const": "0.x-draft"
    },
    "record_type": {
      "const": "gpt_images_perspective_pack"
    },
    "prompt_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "locked",
        "materialized",
        "blocked",
        "rejected"
      ]
    },
    "source_reference_id": {
      "type": "string",
      "minLength": 1
    },
    "target_model": {
      "type": "string",
      "enum": [
        "gpt_images_2",
        "chatgpt_images_2"
      ]
    },
    "target_role": {
      "const": "multi_perspective_element_expander"
    },
    "element_id": {
      "type": "string",
      "minLength": 1
    },
    "element_type": {
      "type": "string",
      "enum": [
        "character",
        "location",
        "prop",
        "wardrobe",
        "style",
        "other"
      ]
    },
    "perspective_policy": {
      "type": "string",
      "enum": [
        "legacy_four_view",
        "three_view_no_rear"
      ],
      "description": "Newly authored element-first records after PR-0 use three_view_no_rear: front_reference, left_reference, right_reference. legacy_four_view exists only for historical records that remain outside the clean SC0001 baseline."
    },
    "shared_preservation_instruction": {
      "type": "string",
      "minLength": 1
    },
    "operator_session_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scene_card_ref": {
          "type": "string",
          "minLength": 1
        },
        "element_sheet_ref": {
          "type": "string",
          "minLength": 1
        },
        "midjourney_prompt_ref": {
          "type": "string",
          "minLength": 1
        },
        "model_guidance_snapshot_ref": {
          "type": "string",
          "minLength": 1,
          "description": "Relative path to the model_guidance_snapshot YAML governing the model + version used for external generation of these perspective prompts. Mirrors generation_params.model_guidance_snapshot_ref on prompt_record."
        }
      }
    },
    "prompts": {
      "oneOf": [
        {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/legacyPerspectivePrompt"
          }
        },
        {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "allOf": [
            {
              "contains": {
                "$ref": "#/$defs/frontReferencePrompt"
              },
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {
                "$ref": "#/$defs/leftReferencePrompt"
              },
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {
                "$ref": "#/$defs/rightReferencePrompt"
              },
              "minContains": 1,
              "maxContains": 1
            }
          ],
          "items": {
            "$ref": "#/$defs/threeViewPerspectivePrompt"
          }
        }
      ]
    },
    "qc_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum_score",
        "all_perspectives_required",
        "failed_perspective_revision_only"
      ],
      "properties": {
        "minimum_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "all_perspectives_required": {
          "type": "boolean"
        },
        "failed_perspective_revision_only": {
          "type": "boolean"
        }
      }
    },
    "downstream_use": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "basePerspectivePrompt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "perspective",
        "prompt_text",
        "constraints",
        "expected_output"
      ],
      "properties": {
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "perspective": {
          "type": "string"
        },
        "prompt_text": {
          "type": "string",
          "minLength": 1
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_output": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "asset_type"
          ],
          "properties": {
            "asset_type": {
              "type": "string",
              "enum": [
                "still",
                "image_set"
              ]
            },
            "aspect_ratio": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "legacyPerspectivePrompt": {
      "allOf": [
        {
          "$ref": "#/$defs/basePerspectivePrompt"
        },
        {
          "properties": {
            "perspective": {
              "enum": [
                "front_hero",
                "three_quarter_left",
                "three_quarter_right",
                "rear_or_side",
                "reverse_angle",
                "side_depth",
                "detail_or_threshold",
                "usage_angle",
                "scale_or_context",
                "left_profile_side",
                "right_profile_side"
              ]
            }
          }
        }
      ]
    },
    "threeViewPerspectivePrompt": {
      "allOf": [
        {
          "$ref": "#/$defs/basePerspectivePrompt"
        },
        {
          "properties": {
            "perspective": {
              "enum": [
                "front_reference",
                "left_reference",
                "right_reference"
              ]
            }
          }
        }
      ]
    },
    "frontReferencePrompt": {
      "type": "object",
      "required": [
        "perspective"
      ],
      "properties": {
        "perspective": {
          "const": "front_reference"
        }
      }
    },
    "leftReferencePrompt": {
      "type": "object",
      "required": [
        "perspective"
      ],
      "properties": {
        "perspective": {
          "const": "left_reference"
        }
      }
    },
    "rightReferencePrompt": {
      "type": "object",
      "required": [
        "perspective"
      ],
      "properties": {
        "perspective": {
          "const": "right_reference"
        }
      }
    }
  }
}
