{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/image_selection.schema.json",
  "title": "Closing Price Image Selection Record",
  "description": "Metadata-only review record for externally generated element candidate images.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "element_id",
    "element_type",
    "selection_round",
    "source_prompt_ids",
    "candidate_images",
    "canonical_images",
    "round_status",
    "pack_manifest_sync"
  ],
  "properties": {
    "element_id": {
      "type": "string",
      "pattern": "^(C\\d{2}|LOC\\d{3}|PROP\\d{3}|WD\\d{3}|STYLE_[A-Z0-9_]+|HERALD_HALO_V\\d{3})$"
    },
    "element_type": {
      "type": "string",
      "enum": ["character", "location", "prop", "wardrobe", "style_ref", "other"]
    },
    "selection_round": {
      "type": "integer",
      "minimum": 1
    },
    "source_prompt_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^SC\\d{4}__[a-z0-9\\-]+__v\\d{2}$"
      }
    },
    "candidate_images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "status", "reason", "quality_scores"],
        "properties": {
          "asset_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "external_storage_ref": {
            "type": ["string", "null"],
            "maxLength": 500
          },
          "repo_binary_committed": {
            "type": "boolean",
            "default": false
          },
          "status": {
            "type": "string",
            "enum": ["candidate", "selected", "rejected", "canonical", "deprecated"]
          },
          "reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "quality_scores": {
            "$ref": "#/$defs/quality_scores"
          },
          "failure_reason": {
            "oneOf": [
              { "$ref": "#/$defs/failure_reason" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "canonical_images": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    },
    "round_status": {
      "type": "string",
      "enum": ["in_progress", "complete", "needs_prompt_revision", "blocked"]
    },
    "pack_manifest_sync": {
      "type": "string",
      "enum": ["pending", "applied"]
    },
    "review_notes": {
      "type": "string",
      "maxLength": 2000
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "$defs": {
    "quality_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "identity_consistency",
        "source_grounding",
        "style_compliance",
        "continuity",
        "production_usability"
      ],
      "properties": {
        "identity_consistency": { "type": "integer", "minimum": 1, "maximum": 5 },
        "source_grounding": { "type": "integer", "minimum": 1, "maximum": 5 },
        "style_compliance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "continuity": { "type": "integer", "minimum": 1, "maximum": 5 },
        "production_usability": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "failure_reason": {
      "type": "string",
      "enum": [
        "source_missing",
        "continuity_unresolved",
        "model_guidance_stale",
        "output_too_stylized",
        "identity_drift",
        "camera_drift",
        "storage_policy_violation",
        "schema_validation_error",
        "unsourced_assertion",
        "continuity_contradiction"
      ]
    }
  }
}
