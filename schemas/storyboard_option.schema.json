{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/storyboard_option.schema.json",
  "title": "Closing Price Storyboard Options Record",
  "description": "Metadata-only candidate storyboard option board for one scene.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scene_id",
    "round",
    "source_refs",
    "options",
    "selected_option",
    "review_status",
    "storage_policy"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_card",
        "scene_excerpt"
      ],
      "properties": {
        "scene_card": {
          "type": "string",
          "minLength": 1
        },
        "scene_excerpt": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "options": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "option_id",
          "purpose",
          "camera_angle",
          "framing",
          "movement",
          "lighting",
          "source_field",
          "prompt_ids",
          "status"
        ],
        "properties": {
          "option_id": {
            "type": "string",
            "pattern": "^SC\\d{4}_SB\\d{2}$"
          },
          "purpose": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "camera_angle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "framing": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "movement": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "lighting": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "source_field": {
            "type": "string",
            "minLength": 1,
            "maxLength": 300
          },
          "prompt_ids": {
            "type": "array",
            "maxItems": 0,
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "candidate",
              "blocked",
              "evidence_thin"
            ]
          },
          "aesthetic_pack_refs": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]+$",
              "maxLength": 80
            }
          }
        }
      }
    },
    "selected_option": {
      "type": "null"
    },
    "review_status": {
      "type": "string",
      "const": "pending"
    },
    "storage_policy": {
      "type": "string",
      "const": "no_binary_commits"
    }
  }
}