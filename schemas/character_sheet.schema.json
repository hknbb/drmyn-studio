{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/character_sheet.schema.json",
  "title": "Closing Price Phase 1 Character Sheet",
  "description": "Canonical character planning record for Zone 1 / Phase 1.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "character_id",
    "display_name",
    "cue_name",
    "role",
    "arc_baseline",
    "voice_fingerprint",
    "visual_profile",
    "status",
    "canon_lock"
  ],
  "properties": {
    "character_id": {
      "type": "string",
      "pattern": "^C\\d{2}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "cue_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "role": {
      "type": "string",
      "enum": [
        "PROTAGONIST",
        "ANTAGONIST",
        "ALLY",
        "CATALYST",
        "MIRROR",
        "OBSTACLE",
        "SUPPORTING",
        "MINOR"
      ]
    },
    "arc_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wound", "mask", "want", "need", "initial_arc_phase"],
      "properties": {
        "wound": { "type": "string", "maxLength": 1000 },
        "mask": { "type": "string", "maxLength": 1000 },
        "want": { "type": "string", "maxLength": 500 },
        "need": { "type": "string", "maxLength": 500 },
        "initial_arc_phase": {
          "type": "string",
          "enum": ["MASK", "CRACK", "SHATTER", "GLIMPSE", "INTEGRATION"]
        }
      }
    },
    "voice_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lexicon", "rhythm", "default_tactic"],
      "properties": {
        "lexicon": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 80 }
        },
        "rhythm": { "type": "string", "maxLength": 300 },
        "default_tactic": { "type": "string", "maxLength": 300 },
        "status_signals": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 120 }
        },
        "verbal_tic": { "type": "string", "maxLength": 200 },
        "dialogue_examples": {
          "type": "array",
          "maxItems": 10,
          "items": { "type": "string", "maxLength": 400 }
        }
      }
    },
    "visual_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["age_range", "screen_presence", "costume_logic", "silhouette", "color_bias"],
      "properties": {
        "age_range": { "type": "string", "maxLength": 80 },
        "screen_presence": { "type": "string", "maxLength": 300 },
        "costume_logic": { "type": "string", "maxLength": 500 },
        "silhouette": { "type": "string", "maxLength": 300 },
        "color_bias": { "type": "string", "maxLength": 300 },
        "hair_makeup_notes": { "type": "string", "maxLength": 500 }
      }
    },
    "continuity_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wardrobe_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^WD\\d{3}$" }
        },
        "prop_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^PROP\\d{3}$" }
        },
        "key_scene_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^SC\\d{4}$" }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "locked", "deprecated"]
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "changes_requested", "approved", "rejected"]
    },
    "canon_lock": { "type": "boolean" },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approved_by": { "type": "string" },
        "approved_at": { "type": "string", "format": "date-time" },
        "approval_note": { "type": "string", "maxLength": 1000 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_by": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" },
        "git_commit": { "type": "string", "pattern": "^[a-f0-9]{7,40}$" }
      }
    }
  }
}
