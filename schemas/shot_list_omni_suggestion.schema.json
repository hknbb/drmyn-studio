{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/shot_list_omni_suggestion.schema.json",
  "title": "Closing Price Shot List Omni Suggestion",
  "description": "Metadata-only suggested shot_list_omni derived from a selected storyboard option.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "applied_to_scene_card": {"const": true}
        }
      },
      "then": {
        "properties": {
          "applied_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "else": {
        "properties": {
          "applied_at": {
            "type": "null"
          }
        }
      }
    }
  ],
  "required": [
    "scene_id",
    "source_storyboard_options",
    "source_selected_option",
    "target_duration_seconds",
    "coverage_strategy",
    "scene_action_type",
    "duration_plan",
    "suggested_shot_list",
    "suggested_by",
    "applied_to_scene_card",
    "applied_at",
    "review_status",
    "storage_policy"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "source_storyboard_options": {
      "type": "string",
      "minLength": 1
    },
    "source_selected_option": {
      "type": "string",
      "pattern": "^SC\\d{4}_SB\\d{2}$"
    },
    "target_duration_seconds": {
      "type": "integer",
      "enum": [5, 10, 15]
    },
    "coverage_strategy": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "scene_action_type": {
      "type": "string",
      "enum": [
        "static_tension",
        "dialogue_exchange",
        "discovery_or_reveal",
        "physical_action",
        "object_insert",
        "arrival_or_departure",
        "transition_or_atmosphere"
      ]
    },
    "duration_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_action_type",
        "target_duration_seconds",
        "recommended_shot_count",
        "min_shot_count",
        "max_shot_count",
        "rhythm",
        "duration_slots"
      ],
      "properties": {
        "scene_action_type": {
          "type": "string",
          "enum": [
            "static_tension",
            "dialogue_exchange",
            "discovery_or_reveal",
            "physical_action",
            "object_insert",
            "arrival_or_departure",
            "transition_or_atmosphere"
          ]
        },
        "target_duration_seconds": {
          "type": "integer",
          "enum": [5, 10, 15]
        },
        "recommended_shot_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "min_shot_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "max_shot_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "rhythm": {
          "type": "string",
          "minLength": 1
        },
        "duration_slots": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 15
          }
        }
      }
    },
    "suggested_shot_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "shot_id",
          "role",
          "subject",
          "camera_angle",
          "framing",
          "camera_movement",
          "lighting",
          "duration_seconds",
          "source_storyboard_option",
          "source_coverage_role"
        ],
        "properties": {
          "shot_id": {
            "type": "string",
            "pattern": "^SC\\d{4}_OMNI\\d{2}$"
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "subject": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "camera_angle": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "framing": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "camera_movement": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "lighting": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "duration_seconds": {
            "type": "integer",
            "minimum": 1,
            "maximum": 15
          },
          "source_storyboard_option": {
            "type": "string",
            "pattern": "^SC\\d{4}_SB\\d{2}$"
          },
          "source_coverage_role": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    },
    "suggested_by": {
      "type": "string",
      "const": "storyboard_agent"
    },
    "applied_to_scene_card": {
      "type": "boolean"
    },
    "applied_at": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "format": "date-time"}
      ]
    },
    "review_status": {
      "type": "string",
      "enum": ["pending", "needs_revision", "accepted_by_human"]
    },
    "storage_policy": {
      "type": "string",
      "const": "no_binary_commits"
    }
  }
}
