{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/prompt_record.schema.json",
  "title": "Closing Price Phase 1 Prompt Record",
  "description": "Versioned prompt record for GitHub-governed prompt lifecycle management.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prompt_id",
    "scene_id",
    "prompt_type",
    "lifecycle_stage",
    "target_models",
    "source_refs",
    "prompt_text",
    "status",
    "canon_lock"
  ],
  "properties": {
    "prompt_id": {
      "type": "string",
      "pattern": "^SC\\d{4}__[a-z0-9\\-]+__v\\d{2}$"
    },
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "prompt_type": {
      "type": "string",
      "enum": [
        "character",
        "environment",
        "shot_design",
        "still_generation",
        "video_generation",
        "variation",
        "repair",
        "evaluation",
        "t2i_character_element",
        "t2i_location_element",
        "t2i_prop_element",
        "t2i_style_reference",
        "t2i_wardrobe_element",
        "omni_instruction",
        "lipsync_audio",
        "lipsync_shot",
        "color_lut",
        "sfx_design"
      ]
    },
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "locked",
        "deprecated"
      ]
    },
    "target_models": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "maxLength": 120
      }
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_card",
        "scene_excerpt"
      ],
      "properties": {
        "scene_card": {
          "type": "string"
        },
        "scene_excerpt": {
          "type": "string"
        },
        "character_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^C\\d{2}$"
          }
        },
        "location_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^LOC\\d{3}$"
          }
        },
        "prop_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^PROP\\d{3}$"
          }
        },
        "wardrobe_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^WD\\d{3}$"
          }
        },
        "storyboard_options": {
          "type": "string",
          "minLength": 1
        },
        "shot_list_omni_suggestion": {
          "type": "string",
          "minLength": 1
        },
        "omni_set_ref": {
          "type": "string",
          "minLength": 1
        },
        "aesthetic_refs": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]+$",
            "maxLength": 80
          }
        }
      }
    },
    "prompt_text": {
      "type": "string",
      "minLength": 1
    },
    "negative_prompt": {
      "type": "string"
    },
    "generation_params": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_guidance_mode": {
          "type": "string",
          "const": "dynamic_snapshot",
          "description": "Indicates this record uses dynamic model guidance snapshots for version resolution."
        },
        "model_guidance_snapshot_ref": {
          "type": "string",
          "description": "Relative path to the model guidance snapshot file used during generation (e.g., model_guidance_snapshots/kling/20260508T140000Z_kling_omni_video_best_available.yaml)."
        },
        "provider": {
          "type": "string",
          "enum": ["kling", "midjourney", "openai", "google"],
          "description": "Provider platform resolved from the snapshot."
        },
        "provider_surface": {
          "type": "string",
          "enum": ["web_ui", "api", "app", "manual_external", "chatgpt_ui", "gemini_app"],
          "description": "How the model is accessed (e.g., api, web_ui, chatgpt_ui, gemini_app)."
        },
        "resolved_model_name": {
          "type": "string",
          "description": "The actual model name resolved from the snapshot at generation time (e.g., 'Kling 3.0 Omni', 'V8.1', 'gpt-image-2', 'Nano Banana Pro / gemini-3-pro-image-preview')."
        },
        "resolved_model_role": {
          "type": "string",
          "enum": ["current_default", "latest_available", "best_for_this_task", "feature_required"],
          "description": "Which role from the snapshot was used for resolution."
        },
        "guidance_observed_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the snapshot was observed/created (from snapshot observed_at)."
        },
        "guidance_expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the snapshot expires and requires refresh (from snapshot expires_at)."
        }
      }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "asset_type": {
          "type": "string",
          "enum": [
            "still",
            "clip",
            "image_set",
            "video_variant",
            "evaluation_text"
          ]
        },
        "aspect_ratio": {
          "type": "string",
          "maxLength": 40
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "variation_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "approved",
        "locked",
        "deprecated"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "pending",
        "changes_requested",
        "approved",
        "rejected"
      ]
    },
    "canon_lock": {
      "type": "boolean"
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approved_by": {
          "type": "string"
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        },
        "approval_note": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "created_by": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_by": {
          "type": "string"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        }
      }
    }
  }
}