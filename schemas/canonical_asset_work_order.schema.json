{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/canonical_asset_work_order.schema.json",
  "title": "Canonical Asset Work Orders",
  "description": "Metadata-only work orders for missing canonical reference assets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scene_id",
    "report_at",
    "source_readiness_ref",
    "report_status",
    "summary",
    "work_orders",
    "storage_policy",
    "canonical_assets_created",
    "pack_manifest_mutation_performed",
    "lock_action_performed",
    "external_generation_performed",
    "binary_outputs_created",
    "lifecycle_promotion_performed"
  ],
  "properties": {
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "report_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_readiness_ref": {
      "type": "string",
      "minLength": 1
    },
    "report_status": {
      "type": "string",
      "const": "work_orders_open"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_work_orders",
        "asset_creation_performed",
        "pack_locking_performed",
        "external_generation_performed",
        "packs_ready_for_lock_review"
      ],
      "properties": {
        "total_work_orders": {
          "type": "integer",
          "minimum": 0
        },
        "asset_creation_performed": {
          "type": "boolean",
          "const": false
        },
        "pack_locking_performed": {
          "type": "boolean",
          "const": false
        },
        "external_generation_performed": {
          "type": "boolean",
          "const": false
        },
        "packs_ready_for_lock_review": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "work_orders": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "work_order_id",
          "element_id",
          "element_type",
          "pack_path",
          "source_pack_readiness",
          "required_asset_groups",
          "provenance_required",
          "copyright_required",
          "intake_ready_to_proceed_required",
          "lfs_required",
          "blocking_notes",
          "missing_requirements",
          "acceptance_checklist",
          "forbidden_actions"
        ],
        "properties": {
          "work_order_id": {
            "type": "string",
            "minLength": 1
          },
          "element_id": {
            "type": "string",
            "minLength": 1
          },
          "element_type": {
            "type": "string",
            "enum": ["character", "location", "prop", "unknown"]
          },
          "pack_path": {
            "type": "string",
            "minLength": 1
          },
          "source_pack_readiness": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "pack_manifest_ref",
              "image_intake_manifest_ref",
              "source_notes_ref",
              "pack_status",
              "canonical_asset_count",
              "source_status",
              "copyright_review",
              "provenance_review",
              "intake_ready_to_proceed"
            ],
            "properties": {
              "pack_manifest_ref": { "type": ["string", "null"] },
              "image_intake_manifest_ref": { "type": "string" },
              "source_notes_ref": { "type": ["string", "null"] },
              "pack_status": { "type": ["string", "null"] },
              "canonical_asset_count": { "type": ["integer", "null"], "minimum": 0 },
              "source_status": { "type": ["string", "null"] },
              "copyright_review": { "type": ["string", "null"] },
              "provenance_review": { "type": ["string", "null"] },
              "intake_ready_to_proceed": { "type": ["boolean", "null"] }
            }
          },
          "required_asset_groups": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "group_id",
                "group_type",
                "target_path",
                "context",
                "required_views",
                "notes",
                "source_status"
              ],
              "properties": {
                "group_id": { "type": "string", "minLength": 1 },
                "group_type": { "type": "string", "minLength": 1 },
                "target_path": { "type": "string", "minLength": 1 },
                "context": { "type": "string" },
                "required_views": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "minLength": 1 }
                },
                "notes": { "type": "string" },
                "source_status": { "type": "string", "minLength": 1 }
              }
            }
          },
          "provenance_required": { "type": "boolean", "const": true },
          "copyright_required": { "type": "boolean", "const": true },
          "intake_ready_to_proceed_required": { "type": "boolean", "const": true },
          "lfs_required": { "type": "boolean", "const": true },
          "blocking_notes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "missing_requirements": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "acceptance_checklist": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "storage_policy": {
      "type": "string",
      "const": "no_binary_commits"
    },
    "canonical_assets_created": {
      "type": "boolean",
      "const": false
    },
    "pack_manifest_mutation_performed": {
      "type": "boolean",
      "const": false
    },
    "lock_action_performed": {
      "type": "boolean",
      "const": false
    },
    "external_generation_performed": {
      "type": "boolean",
      "const": false
    },
    "binary_outputs_created": {
      "type": "boolean",
      "const": false
    },
    "lifecycle_promotion_performed": {
      "type": "boolean",
      "const": false
    }
  }
}
