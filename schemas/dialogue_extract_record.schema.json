{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drmyn-studio/schemas/dialogue_extract_record.schema.json",
  "title": "Dialogue Extract Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "dialogue_extract_id",
    "status",
    "scene_id",
    "source_screenplay_span",
    "speakers",
    "raw_lines",
    "dialogue_function",
    "emotional_subtext",
    "target_language",
    "language_support_status"
  ],
  "properties": {
    "schema_version": {
      "const": "0.x-draft"
    },
    "record_type": {
      "const": "dialogue_extract_record"
    },
    "dialogue_extract_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "approved",
        "locked",
        "materialized",
        "blocked",
        "rejected"
      ]
    },
    "scene_id": {
      "type": "string",
      "pattern": "^SC\\d{4}$"
    },
    "source_screenplay_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_line",
        "end_line"
      ],
      "properties": {
        "start_line": {
          "type": "integer",
          "minimum": 1
        },
        "end_line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "speakers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "character_id",
          "display_name"
        ],
        "properties": {
          "character_id": {
            "type": "string",
            "minLength": 1
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "raw_lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "speaker",
          "text"
        ],
        "properties": {
          "speaker": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dialogue_function": {
      "type": "string",
      "minLength": 1
    },
    "emotional_subtext": {
      "type": "string",
      "minLength": 1
    },
    "target_language": {
      "type": "string",
      "minLength": 1
    },
    "language_support_status": {
      "type": "string",
      "enum": [
        "officially_supported",
        "unsupported_or_translation_risk",
        "unknown_requires_snapshot"
      ]
    },
    "source_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "scene_excerpt_ref": {
          "type": "string",
          "minLength": 1
        },
        "operator_session_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
