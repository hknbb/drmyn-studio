{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/canonical_asset_intake_instruction.schema.json",
  "title": "Canonical Asset Intake Instructions",
  "description": "Human-facing metadata-only canonical asset acquisition checklist.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scene_id",
    "report_at",
    "source_intake_scaffold_ref",
    "report_status",
    "summary",
    "instructions",
    "storage_policy",
    "canonical_assets_created",
    "pack_manifest_mutation_performed",
    "lock_action_performed",
    "copyright_completion_claimed",
    "provenance_completion_claimed",
    "external_generation_performed",
    "binary_outputs_created",
    "lifecycle_promotion_performed"
  ],
  "properties": {
    "scene_id": { "type": "string", "pattern": "^SC\\d{4}$" },
    "report_at": { "type": "string", "format": "date-time" },
    "source_intake_scaffold_ref": { "type": "string", "minLength": 1 },
    "report_status": {
      "type": "string",
      "const": "human_intake_instructions_ready"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_instructions",
        "canonical_assets_created",
        "pack_locking_performed",
        "pack_manifest_mutation_performed",
        "external_generation_performed"
      ],
      "properties": {
        "total_instructions": { "type": "integer", "minimum": 0 },
        "canonical_assets_created": { "type": "boolean", "const": false },
        "pack_locking_performed": { "type": "boolean", "const": false },
        "pack_manifest_mutation_performed": { "type": "boolean", "const": false },
        "external_generation_performed": { "type": "boolean", "const": false }
      }
    },
    "instructions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "instruction_id",
          "work_order_id",
          "element_id",
          "element_type",
          "group_id",
          "target_dir",
          "intake_slot_ref",
          "required_asset_count",
          "required_views",
          "guidance_sources",
          "prompt_guidance",
          "operator_steps",
          "intake_ready_to_proceed_conditions",
          "forbidden_actions",
          "status_after_this_batch"
        ],
        "properties": {
          "instruction_id": { "type": "string", "minLength": 1 },
          "work_order_id": { "type": "string", "minLength": 1 },
          "element_id": { "type": "string", "minLength": 1 },
          "element_type": {
            "type": "string",
            "enum": ["character", "location", "prop", "unknown"]
          },
          "group_id": { "type": "string", "minLength": 1 },
          "target_dir": { "type": "string", "minLength": 1 },
          "intake_slot_ref": { "type": "string", "minLength": 1 },
          "required_asset_count": { "type": "string", "minLength": 1 },
          "required_views": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "guidance_sources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "prompt_guidance": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "operator_steps": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "intake_ready_to_proceed_conditions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "forbidden_actions": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "status_after_this_batch": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_status",
              "copyright_review",
              "provenance_review",
              "intake_ready_to_proceed",
              "canonical_assets_committed"
            ],
            "properties": {
              "source_status": { "type": "string", "const": "not_collected" },
              "copyright_review": { "type": "string", "const": "pending" },
              "provenance_review": { "type": "string", "const": "pending" },
              "intake_ready_to_proceed": { "type": "boolean", "const": false },
              "canonical_assets_committed": {
                "type": "array",
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    "storage_policy": {
      "type": "string",
      "enum": ["no_binary_commits", "git_lfs_approved_references_only"]
    },
    "canonical_assets_created": { "type": "boolean", "const": false },
    "pack_manifest_mutation_performed": { "type": "boolean", "const": false },
    "lock_action_performed": { "type": "boolean", "const": false },
    "copyright_completion_claimed": { "type": "boolean", "const": false },
    "provenance_completion_claimed": { "type": "boolean", "const": false },
    "external_generation_performed": { "type": "boolean", "const": false },
    "binary_outputs_created": { "type": "boolean", "const": false },
    "lifecycle_promotion_performed": { "type": "boolean", "const": false }
  }
}
