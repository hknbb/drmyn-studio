# Normalize line endings
* text=auto

# Force LF for text files
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.cff text eol=lf
*.toml text eol=lf

# Treat ZIP as binary
*.zip binary

# Canonical element image assets — Git LFS (visual_dev/elements/ only)
visual_dev/elements/**/*.png  filter=lfs diff=lfs merge=lfs -text
visual_dev/elements/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
visual_dev/elements/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
visual_dev/elements/**/*.webp filter=lfs diff=lfs merge=lfs -text

# Batch 0.75: Locked storyboard keyframes — Git LFS (visual_dev/storyboards/ only)
# Storyboard candidate stills stay in external storage (.gitignore blocks visual_dev/storyboards/**/candidates/)
# Only human-selected, locked keyframes are committed here.
visual_dev/storyboards/**/*.png  filter=lfs diff=lfs merge=lfs -text
visual_dev/storyboards/**/*.jpg  filter=lfs diff=lfs merge=lfs -text
visual_dev/storyboards/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
visual_dev/storyboards/**/*.webp filter=lfs diff=lfs merge=lfs -text
